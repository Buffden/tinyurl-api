      "updated": 1773129879764,
      "link": null,
      "locked": false,
      "text": "WITH (fillfactor = 90)  →  10% page space reserved for HOT\nupdates\nTOAST: original_url > ~2KB stored in TOAST table (avg 100\nchars is safe)\nSequence cache = 100  →  reduces contention at high create QPS",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 9,
      "containerId": null,
      "originalText": "WITH (fillfactor = 90)  →  10% page space reserved for HOT updates\nTOAST: original_url > ~2KB stored in TOAST table (avg 100 chars is safe)\nSequence cache = 100  →  reduces contention at high create QPS",
      "autoResize": false,
      "lineHeight": 1.2
    },
