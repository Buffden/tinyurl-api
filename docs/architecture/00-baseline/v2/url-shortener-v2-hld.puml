@startuml URLShortenerV2
title URL Shortener v2 - High Level Design (Scale + Abuse Safety + Reliability)

left to right direction
skinparam linetype ortho
skinparam shadowing false
skinparam componentStyle rectangle
skinparam defaultFontName Arial
skinparam defaultFontSize 11
skinparam nodesep 170
skinparam ranksep 90
skinparam packagePadding 26
skinparam componentPadding 12
skinparam component<<spacer>> {
    BorderColor transparent
    BackgroundColor transparent
    FontColor transparent
}

' ---------------- LEGEND ----------------
legend right
  |= Color |= Path |
  |<#4C9BE8> Blue  | Read Path  (GET /{code})   |
  |<#FF0000> Red   | Write Path (POST /shorten) |
endlegend

' ---------------- CLIENT ----------------
actor User

' ---------------- INTERNET ----------------
package "Public Internet" #LightGray {
    cloud "DNS\n(go.buffden.com)" as DNS
}

' ---------------- AWS REGION ----------------
package "AWS Region (Single Region)" #LightBlue {

    package "Entry Layer" #LightGreen {
        [Load Balancer\n(L4 / L7)] as LB
    }

    package "Application Tier" #LightYellow {
        [Nginx\n(TLS Termination + Reverse Proxy)] as NGINX
        [URL Shortener App\n(Stateless Instances + Token Bucket RL)] as APP
    }

    package "Cache Layer" #LightPink {
        database "Redis\n(Cache-Aside)\n+ Negative Caching" as REDIS
    }

    package "Data Tier" #LightCoral {
        [ ] as DATA_GAP <<spacer>>
        database "PostgreSQL\nPrimary DB" as DB
    }

    package "Observability" #LightSteelBlue {
        [Metrics\n(P95, P99, QPS)] as METRICS
        [Structured Logs] as LOGS
    }
}

' Layout alignment
NGINX -[hidden]-> APP
APP -[hidden]-> REDIS
REDIS -[hidden]-> DATA_GAP
DATA_GAP -[hidden]-> DB

' ---------------- SHARED PATH ----------------

User --> DNS : Resolve \n domain

' ---------------- READ PATH (blue) ----------------

User -[#4C9BE8]-> LB : [READ] GET /{code}
LB -[#4C9BE8]-> NGINX
NGINX -[#4C9BE8]-> APP
APP -[#4C9BE8]-> REDIS : Lookup short_code
REDIS -[#4C9BE8]-> APP : Cache hit\nor NULL (negative cache)
APP -[#4C9BE8]-> DB : Cache miss lookup
DB -[#4C9BE8]-> APP : Return mapping
APP -[#4C9BE8]-> REDIS : Cache populate (TTL)\nor Store NULL (TTL)
APP -[#4C9BE8]-> User : HTTP 301/302 Redirect\nor HTTP 404 Not Found

' ---------------- WRITE PATH (red) ----------------

User -[#FF0000]-> LB : [WRITE] POST /shorten
LB -[#FF0000]-> NGINX
NGINX -[#FF0000]-> APP
APP -[#FF0000]-> DB : INSERT mapping
DB -[#FF0000]-> APP : Confirm write
APP -[#FF0000]-> REDIS : Warm cache
APP -[#FF0000]-> User : Return short URL

' ---------------- OBSERVABILITY (both paths) ----------------

APP --> METRICS : Emit \n latency / RPS
APP --> LOGS : Structured \n logging

@enduml