      "updated": 1773337041571,
      "link": null,
      "locked": false,
      "text": "v2 only: Feature-flagged (tinyurl.features.custom-alias). UNIQUE constraint is source\nof truth for alias uniqueness. Advisory pre-check avoids hitting constraint in happy path.\nStricter rate limit: 2/min vs 5/min standard. Alias reserved even after expiry.",
      "fontSize": 11,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "middle",
      "baseline": 10,
      "containerId": "note-design",
      "originalText": "v2 only: Feature-flagged (tinyurl.features.custom-alias). UNIQUE constraint is source\nof truth for alias uniqueness. Advisory pre-check avoids hitting constraint in happy path.\nStricter rate limit: 2/min vs 5/min standard. Alias reserved even after expiry.",
      "autoResize": true,
      "lineHeight": 1.25,
      "index": "aj",
      "frameId": null
    }
