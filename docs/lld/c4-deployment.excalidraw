      "updated": 1773280849319,
      "link": null,
      "locked": false,
      "text": "<<container>> postgres\nImage: postgres:16-alpine\nPort: 5432 (internal only — exposed 5433:5432 for dev)\nVolumes: pg-data:/var/lib/postgresql/data\n         ./migrations/ → /docker-entrypoint-initdb.d/\nEnv: POSTGRES_DB=tinyurl, POSTGRES_USER, POSTGRES_PASSWORD\nHealth check: pg_isready -U tinyurl",
      "fontSize": 12,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
